-- 1. CHỨC NĂNG FLY (BAY)
local flyBtn = CreateButton("FLY: OFF", Color3.fromRGB(150, 0, 0))
local flying = false
local flySpeed = 50
local flyBodyVelocity, flyBodyGyro
local flyConnection

flyBtn.MouseButton1Click:Connect(function()
    flying = not flying
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if flying then
        flyBtn.Text = "FLY: ON"
        flyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        
        -- Tạo động cơ bay
        flyBodyVelocity = Instance.new("BodyVelocity", char.HumanoidRootPart)
        flyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        
        flyBodyGyro = Instance.new("BodyGyro", char.HumanoidRootPart)
        flyBodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        flyBodyGyro.P = 10000
        
        char.Humanoid.PlatformStand = true -- Tắt va chạm chân
        
        -- Điều khiển bay theo góc nhìn Camera và Joystick (trên điện thoại)
        flyConnection = runService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            local moveDir = char.Humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                flyBodyVelocity.Velocity = cam.CFrame.LookVector * (moveDir.Z * -flySpeed) + cam.CFrame.RightVector * (moveDir.X * flySpeed)
            else
                flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
            flyBodyGyro.CFrame = cam.CFrame
        end)
    else
        flyBtn.Text = "FLY: OFF"
        flyBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
        if flyBodyGyro then flyBodyGyro:Destroy() end
        if flyConnection then flyConnection:Disconnect() end
        char.Humanoid.PlatformStand = false
    end
end)

