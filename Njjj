Instance.new("UICorner", delayInput)

local autoClickBtn = Instance.new("TextButton", autoClickFrame)
autoClickBtn.Size = UDim2.new(1, 0, 0, 30)
autoClickBtn.Position = UDim2.new(0, 0, 0, 30)
autoClickBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
autoClickBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
